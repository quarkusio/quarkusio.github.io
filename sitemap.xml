---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  {% for section in site.data.sitemap-links.sections %}
    {% for link in section.links %}
      {% unless link.external %}
  <url>
    <loc>{{ site.url }}{{ link.url }}</loc>
    <changefreq>{{ link.changefreq | default: 'monthly' }}</changefreq>
    <priority>{{ link.priority | default: '0.5' }}</priority>
  </url>
      {% endunless %}
    {% endfor %}
    {% if section.subsections %}
      {% for subsection in section.subsections %}
        {% for link in subsection.links %}
          {% unless link.external %}
  <url>
    <loc>{{ site.url }}{{ link.url }}</loc>
    <changefreq>{{ link.changefreq | default: 'monthly' }}</changefreq>
    <priority>{{ link.priority | default: '0.5' }}</priority>
  </url>
          {% endunless %}
        {% endfor %}
      {% endfor %}
    {% endif %}
  {% endfor %}
</urlset>

